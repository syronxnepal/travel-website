{
  "name": "travel-cms-server",
  "version": "1.0.0",
  "description": "Backend server for Travel CMS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "db:init": "ts-node src/scripts/initDatabase.ts",
    "db:sync": "NODE_ENV=development ts-node -r dotenv/config src/scripts/syncDatabase.ts",
    "db:seed": "NODE_ENV=development ts-node -r dotenv/config src/scripts/seedTreks.ts",
    "db:seed:api": "ts-node -r dotenv/config src/scripts/seedTreksViaAPI.ts",
    "db:seed:tours": "ts-node -r dotenv/config src/scripts/seedToursAndShortToursViaAPI.ts",
    "user:create": "NODE_ENV=development ts-node -r dotenv/config src/scripts/createUser.ts"
  },
  "keywords": [
    "travel",
    "cms",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "image-size": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "stripe": "^20.3.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
